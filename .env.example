# Domain chính thức cho SEO (canonical, sitemap, OG, robots).
# Nên đặt = domain production của bạn, vd: https://martian.vercel.app hoặc domain riêng.
# Nếu bỏ trống, sẽ tự dùng domain Vercel (VERCEL_PROJECT_PRODUCTION_URL).
NEXT_PUBLIC_SITE_URL=

# Bộ đếm lượt tải (Upstash Redis / Vercel KV). Bỏ trống => đếm tạm trong RAM.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Hoặc dùng tên biến của Upstash:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Tùy chọn: token GitHub để tránh rate-limit khi lấy danh sách phiên bản.
GITHUB_TOKEN=
